            },
            {
              "name": "--jb-button-border-radius",
              "description": "Inner button border radius."
            },
            {
              "name": "--jb-button-height",
              "description": "Default button height."
            },
            {
              "name": "--jb-button-font-size",
              "description": "Button font size."
            },
            {
              "name": "--jb-button-color",
              "description": "Button text color."
            },
            {
              "name": "--jb-button-bg-color",
              "description": "Button background color."
